# Keep the build context small and secret-free.

# Virtual environments
.venv/
venv/
env/

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.ipynb_checkpoints/

# Model weights & large binaries. Excluded by default (slim/fallback image does
# not need them). Training checkpoints (optimizer state, etc.) are always excluded.
*.pt
*.pth
*.ckpt
models/
# ...but keep the single LoRA adapter the model-serving image (Dockerfile.model)
# copies in. The slim Dockerfile does not COPY models/, so this only affects it.
!models/instruction_ft_adapter
!models/instruction_ft_adapter/**

# Data & notebooks (not needed at runtime)
data/
notebooks/
reports/
tmp/

# Docs & office files
docs/
*.docx

# Secrets / local config
.env
.env.*

# VCS / IDE / OS
.git/
.gitignore
.idea/
.vscode/
.DS_Store

# Tests
tests/
