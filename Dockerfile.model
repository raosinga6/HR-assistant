# syntax=docker/dockerfile:1
#
# MODEL-serving image: runs the actual fine-tuned model via transformers + peft.
# Unlike the slim `Dockerfile` (fallback mode), this installs torch/transformers
# and copies the LoRA adapter into the image. Runs on CPU (no GPU required).
#
#   az acr build --registry <acr> --image hr-assistant:model-v1 --file Dockerfile.model .
#
# NOTE: model weights under models/ are gitignored, so they are NOT present in a
# fresh git clone. Ensure the adapter directory (e.g. models/instruction_ft_adapter)
# exists in the build context before building. The base Qwen2.5-0.5B model is
# downloaded from the Hugging Face Hub on first run.

FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    HR_FALLBACK=0 \
    HR_DEVICE=cpu \
    HR_MODEL_PATH=models/instruction_ft_adapter \
    HF_HOME=/app/.hf \
    STREAMLIT_SERVER_PORT=8501 \
    STREAMLIT_SERVER_ADDRESS=0.0.0.0

WORKDIR /app

# Install the CPU build of torch first (smaller than the default CUDA wheel),
# then the rest of the model stack.
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu
COPY requirements-model.txt .
RUN pip install --no-cache-dir -r requirements-model.txt

# Application code + model adapter (see NOTE above about gitignored weights).
COPY .streamlit/ ./.streamlit/
COPY src/ ./src/
COPY models/ ./models/

RUN useradd --create-home --uid 10001 appuser \
    && mkdir -p /app/.hf \
    && chown -R appuser:appuser /app
USER appuser

EXPOSE 8501

HEALTHCHECK --interval=30s --timeout=5s --start-period=60s --retries=3 \
    CMD python -c "import urllib.request,sys; sys.exit(0) if urllib.request.urlopen('http://localhost:8501/_stcore/health').status==200 else sys.exit(1)" || exit 1

CMD ["streamlit", "run", "src/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
